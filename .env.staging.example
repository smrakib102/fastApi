# Staging .env — sample. Copy to .env.staging on the VPS and fill in.
# IMPORTANT: this file lives ALONGSIDE the prod .env on the same VPS.
#   - DATABASE_URL points at the staging Postgres container (different DB name)
#   - REDIS_URL uses Redis DB index 1 (prod uses 0)
#   - All v4 governance flags default OFF here exactly like prod, so staging
#     is a behavioural mirror until you intentionally flip a flag for testing.

ENVIRONMENT=staging
APP_NAME=ai-agent-system-staging

# --- Postgres (staging) ---
POSTGRES_DB=openclaw_staging
POSTGRES_USER=staginguser
POSTGRES_PASSWORD=CHANGE_ME_STAGING
# host=postgres because we resolve over the staging compose network
DATABASE_URL=postgresql+psycopg://staginguser:CHANGE_ME_STAGING@postgres:5432/openclaw_staging

# --- Redis (staging) — DB index 1 keeps it isolated from prod (index 0) ---
REDIS_URL=redis://redis:6379/1

# --- Admin / tool tokens (DIFFERENT from prod) ---
ADMIN_TOKEN=CHANGE_ME_STAGING_ADMIN
TOOL_API_TOKEN=CHANGE_ME_STAGING_TOOL
AUTH_SECRET_KEY=CHANGE_ME_STAGING_JWT
SECRETS_MASTER_KEY=CHANGE_ME_STAGING_FERNET

# --- Provider keys (can be the same as prod for read-only testing,
#     but use a separate Telegram bot to avoid double-replies) ---
GOOGLE_GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=

PUBLIC_BASE_URL=https://staging.fgvideoschool.com

# --- Build identity (set by deploy script) ---
BUILD_SHA=
BUILD_TAG=staging

# =========================================================================
# v4 production governance — ALL OFF by default. Flip individually as we
# move each phase from "shadow" → "enforce" on staging first, then prod.
# =========================================================================

# Two emergency switches. .env value ALWAYS overrides the DB-backed flag.
SAFE_MODE_ENABLED=false
STRICT_MODE_ENABLED=false

# Tri-state kernels: off | shadow | enforce
VALIDATION_KERNEL_MODE=off
INTENT_VERIFIER_MODE=off
SAFETY_KERNEL_MODE=off
OUTPUT_DEFENCE_MODE=off
LOOP_DETECTOR_MODE=off

# Subsystem feature gates
UNIVERSAL_API_ENABLED=false
MCP_ENABLED=false
DYNAMIC_TOOLS_ENABLED=false
DYNAMIC_TOOLS_ALLOW_FALLBACK=false
PERMISSION_V2_ENABLED=false
PLANNER_GUARDRAILS_ENABLED=false
OPENCLAW_PERSONA_ENABLED=false
HITL_ENABLED=false
DRY_RUN_ENABLED=false
RISK_REGISTRY_ENABLED=false
ACTION_SUMMARISER_ENABLED=false
ALLOW_HTTP_TOOLS=false
