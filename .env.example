ENVIRONMENT=local
APP_NAME=ai-agent-system

POSTGRES_DB=agentdb
POSTGRES_USER=agentuser
POSTGRES_PASSWORD=agentpass
DATABASE_URL=postgresql+psycopg://agentuser:agentpass@localhost:5432/agentdb

REDIS_URL=redis://localhost:6379/0

ADMIN_TOKEN=change-me
TOOL_API_TOKEN=change-me

GOOGLE_GEMINI_API_KEY=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/calendar.readonly

# Phase 8: external base URL used to build Telegram → web bridge links
# (e.g. https://app.example.com). If unset, falls back to the host portion
# of GOOGLE_OAUTH_REDIRECT_URI.
PUBLIC_BASE_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
TELEGRAM_LINK_TTL_SECONDS=600
TELEGRAM_PROMPT_TTL_SECONDS=600
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
# --- Phase 2: NextAuth shadow OAuth (safe defaults) -------------------------
ENABLE_NEXTAUTH_OAUTH=false
ENABLE_VAULT_SYSTEM=false
OAUTH_ROLLOUT_PERCENT=0
OAUTH_ROLLOUT_MODE=hash
OAUTH_ALLOWLIST_USER_IDS=
NEXTAUTH_BASE_URL=
NEXTAUTH_CALLBACK_SECRET=
NEXTAUTH_SIGNATURE_SECRET=
NEXTAUTH_SIGNATURE_SECONDARY_SECRET=
NEXTAUTH_POST_AUTH_REDIRECT_URL=
OAUTH_REQUEST_TTL_SEC=900
OAUTH_PROCESSED_TTL_SECONDS=900
OAUTH_PROCESSING_LOCK_SECONDS=60
OAUTH_ROUTE_TTL_SECONDS=86400
OAUTH_CALLBACK_MAX_SKEW_SECONDS=300
OAUTH_CALLBACK_DRIFT_LOG_SECONDS=60
OAUTH_METRICS_WINDOW_SECONDS=300
OAUTH_CALLBACK_FAILURE_THRESHOLD=25
OAUTH_VAULT_FAILURE_THRESHOLD=10
OAUTH_DUPLICATE_THRESHOLD=50
OAUTH_KILL_SWITCH_TTL_SECONDS=3600
ADMIN_OTP_TTL_SECONDS=600
ADMIN_OTP_RATE_SECONDS=60
ADMIN_OTP_MAX_ATTEMPTS=5
AGENT_MAX_STEPS=8
AGENT_TIMEOUT_SECONDS=120
AGENT_MEMORY_STEPS=6
AGENT_SUMMARY_EVERY=3
AGENT_TOOL_RETRY_LIMIT=2
AGENT_TOOL_RETRY_BACKOFF_SECONDS=2
AGENT_TOOL_RETRY_MAX_BACKOFF_SECONDS=20
AGENT_TOOL_TIMEOUT_SECONDS=25
AGENT_TOOL_KILL_SWITCH_SECONDS=60
AGENT_TOOL_CIRCUIT_BREAKER_FAILURES=3
AGENT_TOOL_CIRCUIT_COOLDOWN_SECONDS=120
AGENT_PROVIDER_CIRCUIT_BREAKER_FAILURES=3
AGENT_PROVIDER_CIRCUIT_COOLDOWN_SECONDS=120
AGENT_MAX_EXECUTION_DEPTH=30
AGENT_MAX_PLAN_CYCLES=3
AGENT_MAX_TOOL_FAILURES=4
AGENT_MAX_TOOL_RETRIES_PER_RUN=6
AGENT_MAX_TOKENS=8000
AGENT_MAX_COST_USD=1.0
AGENT_COST_WARNING_RATIO=0.85
AGENT_TOKEN_WARNING_RATIO=0.85
AGENT_PLANNER_JSON_REPAIR_ATTEMPTS=1
AGENT_RUN_STUCK_SECONDS=300
AGENT_RUN_REQUEUE_LIMIT=1
WORKER_PLANNER_CONCURRENCY=2
WORKER_TOOL_CONCURRENCY=4
WORKER_LONG_CONCURRENCY=1
WORKER_APPROVAL_CONCURRENCY=1
WORKER_HEARTBEAT_SECONDS=60
AGENT_TASK_MAX_RETRIES=3
AGENT_TASK_RETRY_BACKOFF_SECONDS=15

AUTH_SECRET_KEY=change-me
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_MINUTES=60
AUTH_COOKIE_NAME=aiagent_session
AUTH_TOKEN_ISSUER=ai-agent-system
REQUIRE_JTI_FOR_ALL_TOKENS=false
LEGACY_USER_EMAIL=legacy@local

# Encryption
SECRETS_MASTER_KEY=

# SMTP (for admin OTP login)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false

# Optional admin defaults
DEFAULT_MODEL_PROVIDER=
CODE_MODEL_PROVIDER=

# --- Phase 0: Unified chat refactor feature flags ---------------------------
# Master switch. Leave false until cutover (Phase 9).
UNIFIED_CHAT_ENABLED=false
# UNIFIED_CHAT_WEB_ENABLED retired in Patch P1 (collapsed into the master).
UNIFIED_CHAT_TELEGRAM_ENABLED=false
UNIFIED_CHAT_NL_AGENT_BUILDER_ENABLED=false
UNIFIED_CHAT_PERMISSION_CARDS_ENABLED=false

# --- Phase 7: Secrets hardening ---------------------------------------------
# When true, provider keys (OPENAI_API_KEY, GEMINI_API_KEY) and the Telegram
# bot token (TELEGRAM_BOT_TOKEN) are read ONLY from these env vars. The
# Admin and Settings UI hide the corresponding inputs and reject API
# submissions. Recommended for production.
SECRETS_ENV_ONLY=false

# --- Phase 5: Plugin loader -------------------------------------------------
# When true, app/plugins/* is scanned at startup and tool dispatch
# consults the registry before falling back to the legacy if/elif chain
# in app/api/routes/tools.py. Off by default — existing tools are
# unaffected.
PLUGIN_LOADER_ENABLED=true

# --- Phase 6: Workflow engine -----------------------------------------------
# When true, exposes /workflows/run and /workflows/dispatch and registers
# the run_workflow_task Celery task. Off by default.
WORKFLOW_ENGINE_ENABLED=false
